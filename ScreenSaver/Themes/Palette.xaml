<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Couleurs de base ──────────────────────────────────────────────── -->
    <!-- dark theme : black=fond,  white=texte  -->
    <!-- light theme: black=texte, white=fond   -->
    <Color x:Key="Black">#0E0D0C</Color>
    <Color x:Key="White">#F0EDE4</Color>

    <!-- ── Accents ───────────────────────────────────────────────────────── -->
    <Color x:Key="Accent1">#E93F29</Color>
    <Color x:Key="Accent2">#EEA929</Color>
    <Color x:Key="Accent3">#6518EA</Color>
    <Color x:Key="Accent4">#00A745</Color>

    <!-- ── Panel paramètres (neutre, identique dans les deux thèmes) ─────── -->
    <SolidColorBrush x:Key="PanelBgBrush"      Color="#3A3A3A"/>
    <SolidColorBrush x:Key="PanelSurfaceBrush" Color="#444444"/>
    <SolidColorBrush x:Key="PanelTextBrush"    Color="#E0DDD8"/>
    <SolidColorBrush x:Key="PanelMutedBrush"   Color="#888480"/>
    <SolidColorBrush x:Key="PanelBorderBrush"  Color="#505050"/>

</ResourceDictionary>
