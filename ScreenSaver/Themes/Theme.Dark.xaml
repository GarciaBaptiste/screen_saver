<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Colors ────────────────────────────────────────────────────────── -->
    <Color x:Key="BackgroundColor">#1C1C1A</Color>
    <Color x:Key="FaceColor">#252523</Color>        <!-- clock face: slightly lighter than background -->
    <Color x:Key="TextPrimaryColor">#F0EDE4</Color> <!-- off-white: ticks, labels on dark face -->
    <Color x:Key="TextOnDarkColor">#F0EDE4</Color>
    <Color x:Key="AccentColor">#E85D00</Color>
    <Color x:Key="MutedColor">#9E9B94</Color>

    <!-- ── Brushes ─────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BackgroundBrush"  Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="FaceBrush"        Color="{StaticResource FaceColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextOnDarkBrush"  Color="{StaticResource TextOnDarkColor}"/>
    <SolidColorBrush x:Key="AccentBrush"      Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="MutedBrush"       Color="{StaticResource MutedColor}"/>

    <!-- Hour / minute hands: off-white, contrasting on dark face -->
    <SolidColorBrush x:Key="HandBrush"        Color="{StaticResource TextPrimaryColor}"/>

</ResourceDictionary>
