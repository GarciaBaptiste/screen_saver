<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Colors ────────────────────────────────────────────────────────── -->
    <Color x:Key="BackgroundColor">#E8E4DC</Color>
    <Color x:Key="FaceColor">#FAFAF7</Color>
    <Color x:Key="TextPrimaryColor">#1C1C1A</Color>
    <Color x:Key="TextOnDarkColor">#1C1C1A</Color>
    <Color x:Key="AccentColor">#E85D00</Color>
    <Color x:Key="MutedColor">#B0ADA6</Color>

    <!-- ── Brushes ─────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BackgroundBrush"  Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="FaceBrush"        Color="{StaticResource FaceColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextOnDarkBrush"  Color="{StaticResource TextOnDarkColor}"/>
    <SolidColorBrush x:Key="AccentBrush"      Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="MutedBrush"       Color="{StaticResource MutedColor}"/>

    <!-- Hour / minute hands: dark on light background -->
    <SolidColorBrush x:Key="HandBrush"        Color="{StaticResource TextPrimaryColor}"/>

</ResourceDictionary>
