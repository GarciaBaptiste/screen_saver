<Window x:Class="ScreenSaver.Windows.ClockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ScreenSaver.Controls"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Cursor="None"
        Background="Transparent">
    <Grid>
        <!-- Phase 2: fond plein écran, démarre invisible, animé par ClockWindow -->
        <Rectangle x:Name="BackgroundRect"
                   Fill="{DynamicResource BackgroundBrush}"
                   Opacity="0"
                   IsHitTestVisible="False"/>
        <controls:AnalogClock x:Name="ClockControl"/>
        <Rectangle x:Name="GrainOverlay" IsHitTestVisible="False"/>
    </Grid>
</Window>
