<Window x:Class="ScreenSaver.Windows.ClockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ScreenSaver.Controls"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        AllowsTransparency="False"
        Cursor="None"
        Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <controls:AnalogClock/>
        <Rectangle x:Name="GrainOverlay" IsHitTestVisible="False"/>
    </Grid>
</Window>
