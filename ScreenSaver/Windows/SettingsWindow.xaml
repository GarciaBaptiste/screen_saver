<Window x:Class="ScreenSaver.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ScreenSaver.Windows"
        Title="Paramètres — ScreenSaver"
        Width="460" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource PanelBgBrush}">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PanelTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Section" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PanelMutedBrush}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground"  Value="{DynamicResource PanelTextBrush}"/>
            <Setter Property="Margin"      Value="0,4,0,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="Box" Width="16" Height="16" CornerRadius="4"
                                    Background="Transparent"
                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="1.5">
                                <Path x:Name="Check" Data="M 2 8 L 6 12 L 14 4"
                                      Stroke="{DynamicResource AccentBrush}"
                                      StrokeThickness="2" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Box"   Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource PanelTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center" Height="26">
                            <Border x:Name="Track" Height="6" CornerRadius="3"
                                    Background="{DynamicResource PanelBorderBrush}"
                                    VerticalAlignment="Center"/>
                            <Border x:Name="Fill" Height="6" CornerRadius="3"
                                    Background="{DynamicResource AccentBrush}"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left">
                                <Border.Width>
                                    <MultiBinding>
                                        <MultiBinding.Converter>
                                            <local:SliderFillConverter/>
                                        </MultiBinding.Converter>
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Value"/>
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Minimum"/>
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Maximum"/>
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="ActualWidth"/>
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="20" Height="20"
                                                         Fill="{DynamicResource AccentBrush}"
                                                         Stroke="{DynamicResource PanelBgBrush}"
                                                         StrokeThickness="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground"  Value="{DynamicResource PanelMutedBrush}"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg" Background="{DynamicResource PanelSurfaceBrush}"
                                BorderThickness="0"
                                Height="26" CornerRadius="13" Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                        <Setter Property="FontSize"   Value="12"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#555555"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Toggle" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width"  Value="44"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track" CornerRadius="12"
                                Background="{DynamicResource PanelBorderBrush}">
                            <Border x:Name="Thumb" Width="18" Height="18"
                                    CornerRadius="9" Background="White"
                                    HorizontalAlignment="Left"
                                    Margin="3,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Swatch" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width"  Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border x:Name="Ring" CornerRadius="17"
                                    Background="Transparent"
                                    BorderBrush="White" BorderThickness="2"
                                    Margin="-3" Visibility="Hidden"/>
                            <Border x:Name="Bg" CornerRadius="14"
                                    Background="{TemplateBinding Background}"
                                    Opacity="0.75"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Ring" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Bg"   Property="Opacity"    Value="1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RandomSwatch" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width"  Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border x:Name="Ring" CornerRadius="17"
                                    Background="Transparent"
                                    BorderBrush="White" BorderThickness="2"
                                    Margin="-3" Visibility="Hidden"/>
                            <Grid x:Name="Bg" Opacity="0.75">
                                <Grid.Clip>
                                    <EllipseGeometry Center="14,14" RadiusX="14" RadiusY="14"/>
                                </Grid.Clip>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#E93F29" Grid.Row="0" Grid.Column="0"/>
                                <Border Background="#EEA929" Grid.Row="0" Grid.Column="1"/>
                                <Border Background="#6518EA" Grid.Row="1" Grid.Column="0"/>
                                <Border Background="#00A745" Grid.Row="1" Grid.Column="1"/>
                            </Grid>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Ring" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Bg"   Property="Opacity"    Value="1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground"      Value="{DynamicResource PanelTextBrush}"/>
            <Setter Property="Background"      Value="{DynamicResource PanelSurfaceBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="15" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground"        Value="{DynamicResource PanelTextBrush}"/>
            <Setter Property="Background"        Value="{DynamicResource PanelSurfaceBrush}"/>
            <Setter Property="BorderBrush"       Value="{DynamicResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="Width"             Value="120"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground"  Value="{DynamicResource PanelTextBrush}"/>
                        <Setter Property="Background"  Value="{DynamicResource PanelSurfaceBrush}"/>
                        <Setter Property="Padding"     Value="8,5"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#555555"/>
                                <Setter Property="Foreground" Value="{DynamicResource PanelTextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Padding="{TemplateBinding Padding}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" Margin="8,0,0,0"
                                                                  VerticalAlignment="Center"/>
                                                <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0"
                                                      Stroke="{DynamicResource PanelMutedBrush}"
                                                      StrokeThickness="1.5"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,0,24,0"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource PanelTextBrush}"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide"
                                   Placement="Bottom">
                                <Border Background="{DynamicResource PanelSurfaceBrush}"
                                        BorderBrush="{DynamicResource PanelBorderBrush}"
                                        BorderThickness="1" CornerRadius="4"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="28,24,28,24">

        <!-- ── Général ─────────────────────────────────────────────────────── -->
        <TextBlock Text="GÉNÉRAL" Style="{StaticResource Section}"/>

        <!-- Délai d'inactivité -->
        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Délai d'inactivité"/>
            <TextBlock x:Name="ThresholdLabel" Grid.Column="1"
                       Foreground="{DynamicResource PanelMutedBrush}" Margin="8,0,0,0"/>
        </Grid>
        <Slider x:Name="ThresholdSlider"
                Minimum="5" Maximum="3600" IsSnapToTickEnabled="True"
                Ticks="5 10 30 60 90 120 300 600 900 1200 1800 2700 3600"
                Margin="0,0,0,14"
                ValueChanged="OnThresholdChanged"/>

        <!-- Thème -->
        <TextBlock Text="Thème" Margin="0,0,0,8"/>
        <StackPanel x:Name="ThemePanel" Orientation="Horizontal" Margin="0,0,0,16">
            <RadioButton Tag="dark"  Background="#0E0D0C" GroupName="Theme" Style="{StaticResource Swatch}" Margin="0,0,10,0" Checked="OnThemeSwatchChanged"/>
            <RadioButton Tag="light" Background="#E8E4DC" GroupName="Theme" Style="{StaticResource Swatch}"                   Checked="OnThemeSwatchChanged"/>
        </StackPanel>

        <!-- Couleur tonique -->
        <TextBlock Text="Couleur tonique" Margin="0,0,0,8"/>
        <StackPanel x:Name="AccentPanel" Orientation="Horizontal">
            <RadioButton Tag="#E93F29" Background="#E93F29" GroupName="Accent" Style="{StaticResource Swatch}" Margin="0,0,10,0" Checked="OnAccentChanged"/>
            <RadioButton Tag="#EEA929" Background="#EEA929" GroupName="Accent" Style="{StaticResource Swatch}" Margin="0,0,10,0" Checked="OnAccentChanged"/>
            <RadioButton Tag="#6518EA" Background="#6518EA" GroupName="Accent" Style="{StaticResource Swatch}" Margin="0,0,10,0" Checked="OnAccentChanged"/>
            <RadioButton Tag="#00A745" Background="#00A745" GroupName="Accent" Style="{StaticResource Swatch}" Margin="0,0,10,0" Checked="OnAccentChanged"/>
            <RadioButton Tag="random"                       GroupName="Accent" Style="{StaticResource RandomSwatch}"             Checked="OnAccentChanged"/>
        </StackPanel>

        <!-- ── Horloge ─────────────────────────────────────────────────────── -->
        <TextBlock Text="HORLOGE" Style="{StaticResource Section}" Margin="0,24,0,10"/>

        <StackPanel Orientation="Horizontal">
            <ToggleButton x:Name="WatermarkCheck" Style="{StaticResource Toggle}" Margin="0,0,10,0"/>
            <TextBlock Text="Afficher le filigrane numérique" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ── Calendrier ──────────────────────────────────────────────────── -->
        <TextBlock Text="CALENDRIER" Style="{StaticResource Section}" Margin="0,24,0,10"/>

        <StackPanel Orientation="Horizontal">
            <ToggleButton x:Name="MonthGridCheck" Style="{StaticResource Toggle}" Margin="0,0,10,0"/>
            <TextBlock Text="Afficher la grille du mois" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock Text="Premier jour de la semaine" Margin="0,10,0,8"/>
        <StackPanel x:Name="FirstDayPanel" Orientation="Horizontal">
            <RadioButton Content="Lundi"    Tag="Monday" GroupName="FirstDay" Margin="0,0,8,0"/>
            <RadioButton Content="Dimanche" Tag="Sunday" GroupName="FirstDay"/>
        </StackPanel>

        <!-- ── Boutons ─────────────────────────────────────────────────────── -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button Content="Annuler" Width="90" Height="30" Padding="0,0" Margin="0,0,10,0"
                    Click="OnCancel"/>
            <Button Content="Enregistrer" Width="115" Height="30" Padding="0,0"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="White" BorderThickness="0"
                    Click="OnSave"/>
        </StackPanel>

    </StackPanel>
</Window>
