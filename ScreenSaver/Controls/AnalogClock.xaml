<UserControl x:Class="ScreenSaver.Controls.AnalogClock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <!-- Digit watermark rendered outside Viewbox: native resolution, crisp ClearType -->
        <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False"/>
        <Viewbox Stretch="Uniform">
            <!-- Fixed logical canvas — scales uniformly via Viewbox -->
            <Canvas x:Name="ClockCanvas" Width="500" Height="500"/>
        </Viewbox>
    </Grid>
</UserControl>
