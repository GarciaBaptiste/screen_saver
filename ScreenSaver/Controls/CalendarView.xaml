<UserControl x:Class="ScreenSaver.Controls.CalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid">

        <!-- ── Portrait layout (default — secondary screen full height) ────── -->
        <StackPanel x:Name="PortraitPanel"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="Visible">

            <!-- Day of week — small caps, muted -->
            <TextBlock x:Name="DayOfWeekText"
                       FontFamily="Segoe UI Light"
                       FontSize="28"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"
                       TextOptions.TextFormattingMode="Display">
                <TextBlock.Foreground>
                    <DynamicResource ResourceKey="MutedBrush"/>
                </TextBlock.Foreground>
            </TextBlock>

            <!-- Day number — dominant element, ~40 % of screen height -->
            <TextBlock x:Name="DayNumberText"
                       FontFamily="Helvetica Neue, Segoe UI Light"
                       FontSize="280"
                       FontWeight="Light"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,0"
                       TextOptions.TextFormattingMode="Display">
                <TextBlock.Foreground>
                    <DynamicResource ResourceKey="TextOnDarkBrush"/>
                </TextBlock.Foreground>
            </TextBlock>

            <!-- Month / year -->
            <TextBlock x:Name="MonthYearText"
                       FontFamily="Segoe UI Light"
                       FontSize="36"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,40"
                       TextOptions.TextFormattingMode="Display">
                <TextBlock.Foreground>
                    <DynamicResource ResourceKey="MutedBrush"/>
                </TextBlock.Foreground>
            </TextBlock>

            <!-- Month grid -->
            <Grid x:Name="MonthGrid" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- ── Compact landscape layout (single-monitor — half screen) ──────── -->
        <Grid x:Name="LandscapePanel" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: text info -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock x:Name="DayOfWeekTextL"
                           FontFamily="Segoe UI Light"
                           FontSize="20"
                           Margin="0,0,0,8">
                    <TextBlock.Foreground>
                        <DynamicResource ResourceKey="MutedBrush"/>
                    </TextBlock.Foreground>
                </TextBlock>
                <TextBlock x:Name="DayNumberTextL"
                           FontFamily="Helvetica Neue, Segoe UI Light"
                           FontSize="160"
                           FontWeight="Light"
                           Margin="0,0,0,0">
                    <TextBlock.Foreground>
                        <DynamicResource ResourceKey="TextOnDarkBrush"/>
                    </TextBlock.Foreground>
                </TextBlock>
                <TextBlock x:Name="MonthYearTextL"
                           FontFamily="Segoe UI Light"
                           FontSize="22"
                           Margin="0,8,0,0">
                    <TextBlock.Foreground>
                        <DynamicResource ResourceKey="MutedBrush"/>
                    </TextBlock.Foreground>
                </TextBlock>
            </StackPanel>

            <!-- Right: month grid -->
            <Grid x:Name="MonthGridL" Grid.Column="2" VerticalAlignment="Center"/>
        </Grid>

    </Grid>
</UserControl>
