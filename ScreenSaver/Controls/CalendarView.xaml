<UserControl x:Class="ScreenSaver.Controls.CalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid">

        <!-- ── Portrait layout (default — secondary screen full height) ────── -->
        <StackPanel x:Name="PortraitPanel"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="Visible">

            <!-- Day of week — small caps, muted -->
            <TextBlock x:Name="DayOfWeekText"
                       FontFamily="Segoe UI Light"
                       FontSize="28"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,-32"
                       Opacity="0"
                       TextOptions.TextFormattingMode="Display">
                <TextBlock.Foreground>
                    <DynamicResource ResourceKey="MutedBrush"/>
                </TextBlock.Foreground>
            </TextBlock>

            <!-- Day number — dominant element, ~40 % of screen height -->
            <TextBlock x:Name="DayNumberText"
                       FontFamily="Helvetica Neue, Segoe UI Light"
                       FontSize="280"
                       FontWeight="Light"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,0"
                       Opacity="0"
                       TextOptions.TextFormattingMode="Display">
                <TextBlock.Foreground>
                    <DynamicResource ResourceKey="TextOnDarkBrush"/>
                </TextBlock.Foreground>
            </TextBlock>

            <!-- Month / year -->
            <TextBlock x:Name="MonthYearText"
                       FontFamily="Segoe UI Light"
                       FontSize="36"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,64"
                       Opacity="0"
                       TextOptions.TextFormattingMode="Display">
                <TextBlock.Foreground>
                    <DynamicResource ResourceKey="MutedBrush"/>
                </TextBlock.Foreground>
            </TextBlock>

            <!-- Month grid -->
            <Grid x:Name="MonthGrid" HorizontalAlignment="Center" Opacity="0"/>
        </StackPanel>

    </Grid>
</UserControl>
